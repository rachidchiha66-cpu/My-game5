<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body { background: #000; color: #fff; text-align: center; font-family: Arial; padding-top: 50px; }
        .coin { font-size: 120px; cursor: pointer; transition: 0.1s; display: block; }
        .coin:active { transform: scale(0.9); }
        #score { font-size: 50px; color: #ffca28; margin: 20px; }
    </style>
</head>
<body>
    <div id="score">0</div>
    <span class="coin" onclick="tap()">💰</span>
    <h2>اضغط لتربح!</h2>

    <script>
        let score = 0;
        const tg = window.Telegram.WebApp;
        tg.expand(); // لجعل اللعبة تملأ الشاشة

        function tap() {
            score++;
            document.getElementById('score').innerText = score;
            tg.HapticFeedback.impactOccurred('medium'); // اهتزاز للهاتف
        }
    </script>
</body>
</html>
